# Supabase Kong API Gateway — Strategy D image for Railway
# All values are placeholders; real values come from Railway env vars at runtime.

# Routing — point each upstream variable at the corresponding Railway service's
# RAILWAY_PRIVATE_DOMAIN. Example: SUPABASE_AUTH_HOST=${{Auth.RAILWAY_PRIVATE_DOMAIN}}
SUPABASE_AUTH_HOST=auth
SUPABASE_REST_HOST=rest
SUPABASE_REALTIME_HOST=realtime
SUPABASE_STORAGE_HOST=storage
SUPABASE_FUNCTIONS_HOST=functions
SUPABASE_META_HOST=meta
SUPABASE_STUDIO_HOST=studio

# Auth keys
SUPABASE_ANON_KEY=replace-me-anon-jwt
SUPABASE_SERVICE_KEY=replace-me-service-role-jwt
# Optional asymmetric/opaque keys (leave blank to use legacy HS256 only)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Studio basic auth
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=replace-me

# Kong listening port (set to ${PORT} on Railway so it matches generated domain target)
KONG_PROXY_LISTEN=0.0.0.0:8000
